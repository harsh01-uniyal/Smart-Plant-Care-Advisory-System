# Environment Variables for Krushimitra AI Agent

# Sarvam API Key for speech-to-text and suggested queries
SARVAM_API_KEY=your_sarvam_api_key_here

# Google Maps API Key (client-side)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Maps API Key (server-side, alternative)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Application Credentials for Firebase/GCP
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/credentials.json

# Node Environment (development/production)
NODE_ENV=development

# Gemini Project ID
GEMINI_PROJECT_ID=your_gemini_project_id_here

# Gemini Location
GEMINI_LOCATION=us-central1

# Gemini Model
GEMINI_MODEL=gemini-1.5-flash-001

# Port for the server
PORT=4000

# Google Generative AI API Key
GOOGLE_GENERATIVE_AI_API_KEY=your_google_generative_ai_api_key_here

# Perplexity API Key
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Mandi Price API Key
MANDI_PRICE_API_KEY=your_mandi_price_api_key_here